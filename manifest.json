{
  "manifest_version": 3,
  "name": "CodeStack",
  "version": "1.1",
  "description": "Appends multiple code cells/blocks across Jupyter, Colab, GitHub, and ChatGPT into one master clipboard.",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icon.jpeg",
    "48": "icon.jpeg",
    "128": "icon.jpeg"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://colab.research.google.com/*",
        "https://chatgpt.com/*",
        "https://github.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}
